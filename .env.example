# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.
# Never commit real values (.env* is gitignored).

# Supabase — Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxx   # service_role secret key (NOT the anon/publishable key)

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# App auth (shared password gate)
APP_PASSWORD=choose-a-strong-password    # required — without it nobody can log in
AUTH_SECRET=a-long-random-string         # required — used to sign the session cookie
